<Window x:Class="StratusBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StratusBot"
        mc:Ignorable="d"
        Title="StratusBot" Height="600" Width="800"
        MinWidth="350" MinHeight="500"
        Background="LightSteelBlue">
    <Grid>
        <!-- Row 0: Header with bot name and ASCII art -->
        <!-- Row 1: ScrollViewer containing chat display TextBlock -->
        <!-- Row 2: Input row with TextBox and Send Button -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Chat display -->
            <RowDefinition Height="Auto"/>
            <!-- Input row -->
        </Grid.RowDefinitions>
        
            <!-- Header -->
        <StackPanel Grid.Row="0" Margin="10" HorizontalAlignment="Center">
            <TextBlock Text="Stratus Shield" FontSize="24" FontWeight="Bold" Foreground="DarkBlue" HorizontalAlignment="Center"/>
           
            <Viewbox Stretch="Uniform">
                <TextBlock x:Name="AsciiTextBlock" FontFamily="Consolas" FontSize="14" xml:space="preserve" HorizontalAlignment="Center"/>
            </Viewbox>
        </StackPanel>
        
        <!-- User Display -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,5,5,0">
            <!--name must change to reflect actual user -->
            <TextBlock x:Name="UserDisplay" Text="User: John Doe" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"
                    VerticalAlignment="Center"/>
            <Ellipse Name="StatusIndicator" Width="10" Height="10" Fill="Green" Margin="0,0,8,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Chat Display -->
        <Border Grid.Row="1" Margin="10" Background="LightCyan" BorderBrush="LightGray" BorderThickness="1" Padding="5">
            <ScrollViewer Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" ScrollChanged="ChatScrollViewer_ScrollChanged">
                <StackPanel Name="ChatDisplay" Orientation="Vertical">
                    <!-- Chat messages will be added here dynamically -->
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- Input Row -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Input Row -->
            <TextBox x:Name="InputTextBox" Grid.Column="0" Margin="0,0,5,0" FontSize="14"/>
            <!-- Send Button -->
            <Button Name="SendButton" Content="Send"  Width="75" Height="35" Grid.Column="1" Padding="10,5" Click="SendButton_Click"/>


        </Grid>
    </Grid>
</Window>
